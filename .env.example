# ──────────────────────────────────────────────────────────────
# Copy to apps/web/.env.local and fill in real values.
# Never commit real secrets — .env.local is gitignored.
# ──────────────────────────────────────────────────────────────

# Supabase — Project Settings → API Keys (use the modern publishable/secret keys,
# not the legacy anon/service_role keys, which Supabase deprecates by end of 2026).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx   # safe for the browser (RLS-protected)

# Server-only secret key (Edge Functions / server routes). NEVER expose to the browser.
SUPABASE_SECRET_KEY=sb_secret_xxx

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── External services (added in later phases) ──────────────────
# Phase 3 — Food database
USDA_FDC_API_KEY=your-usda-fooddata-central-key   # https://fdc.nal.usda.gov/api-key-signup.html
# Open Food Facts needs no key.

# Phase 4 — AI (NLP + Vision). Default provider: Gemini (free tier).
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key                # https://aistudio.google.com/apikey
# Optional upgrade providers (swappable via AIProvider interface):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
